# RepoKeeper Production Environment Variables
# Copy to .env and fill in your values

# === Required ===

# GitHub personal access token with 'repo' scope
GITHUB_TOKEN=ghp_your_personal_access_token

# Webhook secret (generate with: openssl rand -hex 32)
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# === AI Provider (pick one) ===

# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=sk-ant-your-key

# OpenAI GPT
# OPENAI_API_KEY=sk-your-key

# OpenAI-compatible endpoint (e.g., Azure OpenAI, local proxy)
# OPENAI_BASE_URL=https://your-endpoint.openai.azure.com/v1

# Ollama (free, local inference)
# OLLAMA_URL=http://localhost:11434

# === Docker/Nginx (for docker-compose.prod.yml) ===

# Your domain name (must point to this server's IP)
DOMAIN=repokeeper.example.com

# === Optional ===

# Server port (default: 3001)
# PORT=3001

# Rate limit: max requests per 15-minute window per IP (default: 100)
# RATE_LIMIT_MAX=100
